{
  "name": "volcano-agentic-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Volcano plugins/extensions across agentic IDEs. Thin shells over the Volcano CLI; content is fetched at runtime, never bundled.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "check:no-content-duplicates": "node scripts/check-no-content-duplicates.mjs",
    "check:skill-submodules": "node scripts/check-skill-submodules.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "keytar", "@vscode/vsce-sign"]
  }
}
